{
  "name": "imu-viewer",
  "displayName": "IMU Orientation Viewer",
  "description": "Real-time IMU orientation visualization with 3D view and sensor charts",
  "version": "0.1.0",
  "publisher": "imu-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/imu-viewer/imu-viewer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "imuViewer.open",
        "title": "IMU Viewer: Open"
      }
    ]
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.0",
    "copy-webpack-plugin": "^12.0.0"
  },
  "dependencies": {
    "serialport": "^12.0.0"
  }
}
